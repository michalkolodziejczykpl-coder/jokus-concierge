# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OAuth providers (configured in Supabase Dashboard, not here)
# Google: https://console.cloud.google.com
# Facebook: https://developers.facebook.com
# Apple: https://developer.apple.com

# Payments — Przelewy24
# Sandbox panel: https://sandbox.przelewy24.pl  |  Prod panel: https://panel.przelewy24.pl
# Sprint 3a wires env only; integration code lands in sprint 3c.
PRZELEWY24_ENV=sandbox                # 'sandbox' | 'production'
PRZELEWY24_MERCHANT_ID=
PRZELEWY24_POS_ID=                    # usually identical to MERCHANT_ID
PRZELEWY24_API_KEY=                   # REST API key (Panel → My data → API key)
PRZELEWY24_CRC=                       # CRC sum for client-side param signing
PRZELEWY24_REPORT_KEY=                # key for verifying webhook signatures

# Maps
NEXT_PUBLIC_MAPBOX_TOKEN=
# or
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# AI (voice)
OPENAI_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
